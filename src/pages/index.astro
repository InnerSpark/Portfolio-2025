---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Home">
  <main class="container mx-auto p-4">
    <section aria-labelledby="hero-heading" class="text-center py-16">
      <h1 id="hero-heading" class="text-4xl font-bold text-gray-800">Hi, I'm [Your Name]</h1>
      <p class="text-lg text-gray-600 mt-4">UX Designer specializing in user research, accessibility, and intuitive design.</p>
      <a href="/case-studies" class="mt-6 inline-block bg-blue-600 text-white py-2 px-4 rounded hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" aria-label="View my UX case studies">View My Work</a>
    </section>
    <section aria-labelledby="about-heading" class="py-16">
      <h2 id="about-heading" class="text-3xl font-semibold text-gray-800">About Me</h2>
      <p class="mt-4 text-gray-600">I create user-centered designs with a focus on accessibility and research-driven solutions.</p>
    </section>
  </main>
</Layout>